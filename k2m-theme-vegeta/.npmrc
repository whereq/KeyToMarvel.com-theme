# Allow npm to resolve the React 18/19 peer dependency mismatch in
# @keycloakify/keycloak-account-ui and @keycloakify/keycloak-admin-ui.
# These packages declare peerDependencies on react@^18 but work fine with react@19.
# This is the same approach used in k2m-theme-superhero.
legacy-peer-deps=true
